# ── Ollama Configuration ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en

# ── RAG Pipeline Defaults ─────────────────────────────────────────────────────
MAX_PAPERS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=data
REPORTS_DIR=reports
LOGS_DIR=logs

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
